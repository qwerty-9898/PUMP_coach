# Шаблон переменных окружения. Скопируй в .env и впиши свои значения.
# .env в гите не хранится (он в .gitignore) — секреты остаются у тебя.

# --- Фронтенд (Vite). Только VITE_ и только несекретное (станет публичным!) ---
VITE_APP_NAME=PUMP
# VITE_API_URL=

# --- Бот / бэкенд (секреты, без префикса VITE_) ---
BOT_TOKEN=
# BOT_USERNAME=
# WEBAPP_URL=
# PROVIDER_TOKEN=
# ADMIN_ID=
